# ── Database ─────────────────────────────────────────────
DB_URL=postgresql://postgres:postgres@localhost:5432/pos_db

# ── MinIO ─────────────────────────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=product-images
MINIO_USE_SSL=false

# ── Unsplash (optional) ──────────────────────────────────
# Register a free app at https://unsplash.com/developers
# Leave blank to fall back to https://picsum.photos (no key needed)
UNSPLASH_ACCESS_KEY=

# ── Seeder options ────────────────────────────────────────
PRODUCT_COUNT=1000
CONCURRENCY=8
