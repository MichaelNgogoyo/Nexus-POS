# Template for environment variables
# Copy to .env.prod on VPS and fill in actual values

# ========== DATABASE ==========
DB_URL=jdbc:postgresql://postgres:5432/pos_db
DB_USERNAME=pos_user
DB_PASSWORD=CHANGE_ME_IN_PRODUCTION

# ========== SPRING BOOT ==========
SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080

# ========== KEYCLOAK ==========
KEYCLOAK_ISSUER_URI=https://nexuspos.apperstar.dev/auth/realms/master
KEYCLOAK_CLIENT_ID=pos-client
KEYCLOAK_CLIENT_SECRET=CHANGE_ME_FROM_KEYCLOAK_ADMIN
KEYCLOAK_REDIRECT_URI=https://nexuspos.apperstar.dev/api/callback

# ========== MINIO ==========
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=CHANGE_ME_IN_PRODUCTION
MINIO_BUCKET=product-images

# ========== CORS ==========
CORS_ALLOWED_ORIGINS=https://nexuspos.apperstar.dev

# ========== TAX CONFIGURATION ==========
POS_TAX_RATE=16

# ========== OPTIONAL: Redis Caching ==========
# REDIS_HOST=redis
# REDIS_PORT=6379
# REDIS_PASSWORD=
