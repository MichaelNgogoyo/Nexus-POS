<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<VBox fx:id="root" spacing="12" alignment="CENTER" prefWidth="400" prefHeight="400"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.pos.desktop.ui.controller.LoginController" styleClass="login-root">
    <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>
    <children>
        <Label fx:id="heading" text="Apperster Systems" styleClass="brand-title" />
        <Label fx:id="sub" text="Sign in with Keycloak" styleClass="brand-subtitle" />
        <TextField fx:id="usernameField" promptText="Username" />
        <PasswordField fx:id="passwordField" promptText="Password" />
        <Button fx:id="loginButton" text="Login" styleClass="cta-button" />
        <Label fx:id="statusLabel" textFill="white" styleClass="status-label" />
    </children>
</VBox>
