FROM node:20-alpine AS build
WORKDIR /app

COPY posFrontend/package.json posFrontend/package-lock.json ./
RUN npm ci

COPY posFrontend/. .
RUN npm run build -- --outDir /app/dist --emptyOutDir

FROM nginx:alpine
COPY --from=build /app/dist /usr/share/nginx/html
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
